# Variables d'environnement pour Vibes Arc
# Copiez ce fichier vers .env.local pour le développement local

# Configuration de l'application
VITE_APP_NAME="Vibes Arc"
VITE_APP_VERSION="1.0.0"
VITE_APP_DESCRIPTION="Plateforme de suivi d'identités et d'habitudes"

# Configuration Supabase
VITE_SUPABASE_URL="https://votre-projet.supabase.co"
VITE_SUPABASE_ANON_KEY="votre-clé-anonyme-supabase"

# Configuration de la base de données (optionnel)
# SQLite sera utilisé en local, localStorage en production
DATABASE_URL="file:./data/vibes-arc.db"

# Configuration Vercel
VERCEL_URL=""
VERCEL_ENV="development"

# Web Push (VAPID) — generer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="votre-cle-publique-vapid"
VAPID_PRIVATE_KEY="votre-cle-privee-vapid"
VAPID_SUBJECT="mailto:admin@vibes-arc.local"
VITE_VAPID_PUBLIC_KEY="votre-cle-publique-vapid"  # meme valeur que VAPID_PUBLIC_KEY

# Supabase (cote serveur — API routes Vercel)
SUPABASE_URL="https://votre-projet.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="votre-service-role-key"

# Cron secret (securise le endpoint /api/push/cron appele par pg_cron)
CRON_SECRET="un-secret-aleatoire-long"

# ── Sync Knowledge Base (scripts/sync_knowledge_base.mjs) ──────────────────
# Requis pour synchroniser COACH_KNOWLEDGE_BASE.md → Supabase
# Ne jamais exposer ces valeurs côté client

# URL du projet Supabase (sans slash final)
SUPABASE_URL="https://knpvbwlfdriavrebvzdy.supabase.co"

# Clé Service Role (Supabase Dashboard > Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY="votre-service-role-key"

# user_id de la ligne dans user_knowledge_base à mettre à jour
KNOWLEDGE_BASE_USER_ID="6d3b3bc4-36aa-416e-b291-8c46eae035f1"
